{
  "name": "@softwarity/loading-indicator",
  "version": "1.0.0",
  "author": "Softwarity",
  "license": "MIT",
  "description": "Angular Material 3 expressive loading indicator with smooth morphing animation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/softwarity/loading-indicator.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "angular",
    "material",
    "loading",
    "spinner",
    "indicator",
    "animation",
    "material3",
    "component"
  ],
  "scripts": {
    "ng": "ng",
    "build": "ng build loading-indicator",
    "build:demo": "ng build demo",
    "start:demo": "ng serve demo",
    "cp:archway-ui": "cp -r dist/* ../../softwarity/archway/archway-ui/node_modules/@softwarity/loading-indicator/",
    "watch": "ng build loading-indicator --watch --configuration development",
    "test": "cross-env CHROME_BIN='/usr/bin/google-chrome' ng test",
    "test:ci": "ng test --no-watch --browsers=ChromeHeadless"
  },
  "peerDependencies": {
    "@angular/core": ">=21.0.0"
  },
  "dependencies": {
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@softwarity/interactive-code": "^1.0.3",
    "@angular/animations": "^21.0.3",
    "@angular/build": "^21.0.2",
    "@angular/cdk": "^21.0.2",
    "@angular/cli": "^21.0.2",
    "@angular/common": "^21.0.3",
    "@angular/compiler": "^21.0.3",
    "@angular/compiler-cli": "^21.0.3",
    "@angular/core": "^21.0.3",
    "@angular/forms": "^21.0.3",
    "@angular/material": "^21.0.2",
    "@angular/platform-browser": "^21.0.3",
    "@angular/platform-browser-dynamic": "^21.0.3",
    "@angular/router": "^21.0.3",
    "@softwarity/loading-indicator": "file:dist",
    "@types/jasmine": "~4.6.0",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.2",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^21.0.0",
    "rxjs": "~7.8.1",
    "typescript": "~5.9.3"
  },
  "sideEffects": false
}
